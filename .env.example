# APP
APP_PORT=3000
APP_USE_DOCS=true

# Database connection
DATABASE_HOST=localhost
DATABASE_PORT=27017
DATABASE_USERNAME=db_username
DATABASE_PASSWORD=db_password
DATABASE_NAME=test