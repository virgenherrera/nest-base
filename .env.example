#########################################################
# .env file                                             #
#                                                       #
# to fill missing (not overriding)                      #
#                                                       #
#                                                       #
# How to to use:                                        #
# - copy this file as .env                              #
# - replace below variables with your system's vars     #
#                                                       #
#########################################################

# App — identity and cross-cutting runtime (AppConfig)
APP_ENV=local
APP_LOG_LEVELS=log,error,warn

# Server — HTTP transport (ServerConfig)
SERVER_PORT=3000
SERVER_HOSTNAME=0.0.0.0
SERVER_ENABLE_CORS=true
SERVER_ENABLE_HELMET=true
SERVER_ENABLE_COMPRESSION=true

# Swagger — OpenAPI documentation (SwaggerConfig)
SWAGGER_ENABLED=false
