{
  "name": "nest-base",
  "version": "1.11.0",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "homepage": "https://github.com/virgenherrera/nest-base#readme",
  "bugs": {
    "url": "https://github.com/virgenherrera/nest-base/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/virgenherrera/nest-base.git"
  },
  "contributors": [
    "Hugo Virgen (https://github.com/virgenherrera)"
  ],
  "packageManager": "pnpm@11.4.0+sha512.f0febc7e37552ab485494a914241b338e0b3580b93d54ce31f00933015880863129038a1b4ae4e414a0ee63ac35bf21197e990172c4a68256450b5636310968f",
  "engines": {
    "node": ">=24.13.0 <25",
    "pnpm": ">=11.0.0 <12"
  },
  "scripts": {
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "test": "pnpm run cleanup && pnpm run test:static && pnpm run test:dynamic && pnpm run build:api-docs && pnpm run build:app",
    "build:app": "nest build -p tsconfig.build.prod.json",
    "build:api-docs": "ts-node -r tsconfig-paths/register ./scripts/build-openapi-artifact.ts",
    "test:doctor": "pnpm run cleanup && pnpm run securityCheck && pnpm run eslintCheck && pnpm run prettierCheck && pnpm run test:dynamic && pnpm run build:app",
    "test:static": "pnpm run securityCheck && pnpm run eslintCheck && pnpm run prettierCheck",
    "test:dynamic": "jest",
    "securityCheck": "pnpm audit --audit-level high",
    "eslintCheck": "eslint '{apps,libs,scripts,src,test}/**/*.ts'",
    "prettierCheck": "prettier --check '{apps,libs,scripts,src,test}/**/*.ts'",
    "prepare": "husky",
    "lintStaged": "lint-staged",
    "cleanup": "rimraf api-docs/ coverage/ dist/",
    "securityFix": "pnpm update",
    "updatePnpm": "corepack up",
    "bumpDependencies": "pnpm run securityFix && pnpm dlx npm-check-updates@17 && pnpm run securityFix"
  },
  "dependencies": {
    "@nestjs/common": "11.1.24",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.24",
    "@nestjs/platform-express": "11.1.24",
    "@nestjs/swagger": "11.4.4",
    "compression": "1.8.1",
    "date-fns": "4.4.0",
    "helmet": "8.2.0",
    "nestjs-zod": "5.4.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.24",
    "@types/compression": "1.8.1",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "25.9.1",
    "@types/supertest": "7.2.0",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "lint-staged": "17.0.7",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "ts-jest": "29.4.11",
    "ts-loader": "9.6.0",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1"
  }
}
