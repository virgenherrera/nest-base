echo '
INFO: This project has a pre-commit hook that runs lintStaged (auto-fix staged files), test:dynamic (unit + e2e), and build (api-docs + compilation).
If necessary, you can disable this with the "--no-verify" flag during the commit.
Example:
    "git commit -m <message> --no-verify"
'

pnpm run lintStaged && \
pnpm run test:dynamic && \
pnpm run build || \
{
  echo "ERROR: Pre-commit checks failed. Please address issues before proceeding."
  exit 1
}
