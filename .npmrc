# Pin every `pnpm add` to an exact version — prevents silent semver drift on future installs
save-exact=true
# Abort install if the project's `engines.node` field does not match the active runtime
engine-strict=true
# Fail if peer dependency requirements cannot be satisfied — surfaces incompatible dep trees early
strict-peer-dependencies=true
# Install missing peers automatically so strict-peer-dependencies does not block valid upgrades
auto-install-peers=true
# Prefer the newest version when multiple ranges are eligible — keeps transitive deps up to date
resolution-mode=highest
# Do not prompt for confirmation before removing orphaned packages — safe in CI
confirm-module-purge=false
